# Images
N8N_IMAGE=n8nio/n8n:latest
POSTGRES_IMAGE=postgres:16-alpine
QDRANT_IMAGE=qdrant/qdrant:latest
OLLAMA_IMAGE=ollama/ollama:latest
NGROK_IMAGE=ngrok/ngrok:latest
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest

# n8n
PUBLIC_BASE_IP=auto
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=replace-with-a-random-32-plus-char-string
N8N_SECURE_COOKIE=false
N8N_LOG_LEVEL=info
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
N8N_TEMPLATES_ENABLED=false
N8N_DEFAULT_LOCALE=es
GENERIC_TIMEZONE=America/Guayaquil
TZ=America/Guayaquil
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# PostgreSQL local
POSTGRES_DB=sercop_crm
POSTGRES_USER=sercop_local
POSTGRES_PASSWORD=change-me
N8N_DB_HOST=host.docker.internal
N8N_DB_PORT=5432
CRM_DB_HOST=localhost
CRM_DB_PORT=5432

# Qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Ollama
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_ORIGINS=*
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_GENERAL_MODEL=qwen3:0.6b
OLLAMA_CODE_MODEL=qwen2.5-coder:0.5b
OLLAMA_EMBED_MODEL=nomic-embed-text

MAILPIT_IMAGE=axllent/mailpit:latest

# ngrok
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# CRM external access
CRM_EXTERNAL_ACCESS_MODE=cloudflare_quick
CRM_EXTERNAL_TARGET_PORT=5050
CRM_NGROK_DOMAIN=

# Email local / Mailpit
RESPONSIBLE_EMAIL=responsable@empresa.com
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Automatizacion SERCOP <notificaciones@hdm.local>

# Workflow tuning
MATCH_THRESHOLD=60
OCDS_YEAR=2026
POLL_MINUTES=30

# Invitation filter
INVITED_COMPANY_NAME=HDM
INVITED_COMPANY_RUC=
INVITATION_SYNC_ACTIVE=true
INVITATION_SYNC_INTERVAL_MINUTES=30




# CRM auth
CRM_ADMIN_LOGIN=admin
CRM_ADMIN_NAME=Administrador CRM
CRM_ADMIN_EMAIL=admin@empresa.local
CRM_AUTH_BOOTSTRAP_PASSWORD=replace-with-crm-password
CRM_REQUIRE_HTTPS=true

# CRM auth legacy fallback
CRM_BASIC_AUTH_PASSWORD=replace-with-crm-password

